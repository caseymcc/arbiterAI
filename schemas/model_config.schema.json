{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://arbiterAI/schemas/model-config/v1.1.0",
  "title": "ArbiterAI Model Configuration",
  "description": "Schema for model configuration files",
  "type": "object",
  "required": ["schema_version", "models"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of this configuration schema",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0", "1.1.0"]
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["model", "provider"],
        "properties": {
          "model": {
            "type": "string",
            "description": "Unique model identifier"
          },
          "version": {
            "type": "string",
            "description": "Model version",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "provider": {
            "type": "string",
            "description": "Model provider/service",
            "enum": ["anthropic", "llama", "openai", "deepseek", "openrouter", "mock"]
          },
          "ranking": {
            "type": "integer",
            "description": "Preference order (higher is better)",
            "minimum": 0,
            "maximum": 100,
            "default": 50
          },
          "mode": {
            "type": "string",
            "description": "Operation mode",
            "default": "chat"
          },
          "api_base": {
            "type": "string",
            "description": "Custom API endpoint URL"
          },
          "file_path": {
            "type": "string",
            "description": "Local model file path"
          },
          "api_key": {
            "type": "string",
            "description": "API key for this model"
          },
          "examples_as_sys_msg": {
            "type": "boolean",
            "description": "Whether to include examples as system messages",
            "default": false
          },
          "download": {
            "type": "object",
            "description": "Download metadata for single-file models",
            "properties": {
              "url": {
                "type": "string",
                "format": "uri",
                "description": "Download URL"
              },
              "sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$",
                "description": "SHA256 checksum"
              },
              "cachePath": {
                "type": "string",
                "description": "Relative cache path"
              }
            },
            "required": ["url", "sha256"]
          },
          "compatibility": {
            "type": "object",
            "properties": {
              "minSchemaVersion": {
                "type": "string",
                "pattern": "^\\d+\\.\\d+\\.\\d+$"
              },
              "maxSchemaVersion": {
                "type": "string",
                "pattern": "^\\d+\\.\\d+\\.\\d+$"
              },
              "minClientVersion": {
                "type": "string",
                "pattern": "^\\d+\\.\\d+\\.\\d+$"
              },
              "maxClientVersion": {
                "type": "string",
                "pattern": "^\\d+\\.\\d+\\.\\d+$"
              }
            }
          },
          "context_window": {
            "type": "integer",
            "description": "Context window size in tokens",
            "minimum": 0
          },
          "max_tokens": {
            "type": "integer",
            "description": "Maximum tokens per completion",
            "minimum": 0
          },
          "max_input_tokens": {
            "type": "integer",
            "description": "Maximum input tokens",
            "minimum": 0
          },
          "max_output_tokens": {
            "type": "integer",
            "description": "Maximum output tokens",
            "minimum": 0
          },
          "pricing": {
            "type": "object",
            "description": "Token pricing information",
            "properties": {
              "prompt_token_cost": {
                "type": "number",
                "minimum": 0
              },
              "completion_token_cost": {
                "type": "number",
                "minimum": 0
              }
            }
          },
          "hardware_requirements": {
            "type": "object",
            "description": "Minimum hardware requirements for local models",
            "properties": {
              "min_system_ram_mb": {
                "type": "integer",
                "description": "Minimum system RAM in MB for CPU offload",
                "minimum": 0
              },
              "parameter_count": {
                "type": "string",
                "description": "Human-readable parameter count (e.g. 7B, 13B, 70B)"
              }
            }
          },
          "context_scaling": {
            "type": "object",
            "description": "Context size scaling based on available VRAM",
            "properties": {
              "base_context": {
                "type": "integer",
                "description": "Context size at minimum VRAM",
                "minimum": 0
              },
              "max_context": {
                "type": "integer",
                "description": "Maximum context the model supports",
                "minimum": 0
              },
              "vram_per_1k_context_mb": {
                "type": "integer",
                "description": "Additional VRAM in MB per 1K context tokens",
                "minimum": 0
              }
            }
          },
          "variants": {
            "type": "array",
            "description": "Quantization variants for local models",
            "items": {
              "type": "object",
              "required": ["quantization"],
              "properties": {
                "quantization": {
                  "type": "string",
                  "description": "Quantization format (e.g. Q4_K_M, Q8_0, F16)"
                },
                "file_size_mb": {
                  "type": "integer",
                  "description": "File size in MB",
                  "minimum": 0
                },
                "min_vram_mb": {
                  "type": "integer",
                  "description": "Minimum VRAM in MB to run this variant",
                  "minimum": 0
                },
                "recommended_vram_mb": {
                  "type": "integer",
                  "description": "Recommended VRAM in MB for good performance",
                  "minimum": 0
                },
                "download": {
                  "type": "object",
                  "description": "Download metadata for this variant (single file)",
                  "properties": {
                    "url": {
                      "type": "string",
                      "format": "uri",
                      "description": "Download URL"
                    },
                    "sha256": {
                      "type": "string",
                      "pattern": "^[a-f0-9]{64}$",
                      "description": "SHA256 checksum"
                    },
                    "filename": {
                      "type": "string",
                      "description": "Local filename for the downloaded model"
                    }
                  },
                  "required": ["url", "filename"]
                },
                "files": {
                  "type": "array",
                  "description": "Download metadata for split/multi-shard GGUF variants. When present, takes precedence over the single download field.",
                  "items": {
                    "type": "object",
                    "properties": {
                      "url": {
                        "type": "string",
                        "format": "uri",
                        "description": "Download URL for this shard"
                      },
                      "sha256": {
                        "type": "string",
                        "pattern": "^[a-f0-9]{64}$",
                        "description": "SHA256 checksum for this shard"
                      },
                      "filename": {
                        "type": "string",
                        "description": "Local filename for this shard"
                      }
                    },
                    "required": ["url", "filename"]
                  },
                  "minItems": 1
                }
              }
            }
          },
          "runtime_options": {
            "type": "object",
            "description": "Runtime options for llama.cpp model loading and inference. Applied as defaults; can be overridden at load time via the API.",
            "properties": {
              "flash_attn": {
                "type": "boolean",
                "description": "Enable or disable flash attention (-fa)"
              },
              "kv_cache_type_k": {
                "type": "string",
                "description": "KV cache data type for keys (-ctk)",
                "enum": ["f32", "f16", "bf16", "q8_0", "q4_0", "q4_1", "q5_0", "q5_1"]
              },
              "kv_cache_type_v": {
                "type": "string",
                "description": "KV cache data type for values (-ctv)",
                "enum": ["f32", "f16", "bf16", "q8_0", "q4_0", "q4_1", "q5_0", "q5_1"]
              },
              "no_mmap": {
                "type": "boolean",
                "description": "Disable memory-mapped file I/O (--no-mmap)"
              },
              "reasoning_budget": {
                "type": "integer",
                "description": "Reasoning token budget (--reasoning-budget). 0 disables reasoning tokens.",
                "minimum": 0
              },
              "swa_full": {
                "type": "boolean",
                "description": "Use full-size sliding window attention cache (--swa-full)"
              },
              "n_gpu_layers": {
                "type": "integer",
                "description": "Number of layers to offload to GPU (-ngl). 99 offloads all.",
                "minimum": 0
              },
              "override_tensor": {
                "type": "string",
                "description": "Tensor override pattern (-ot) for routing tensors to CPU/GPU"
              }
            },
            "additionalProperties": false
          },
          "backend_priority": {
            "type": "array",
            "description": "Ordered preference for GPU backends. First available backend is used.",
            "items": {
              "type": "string",
              "enum": ["vulkan", "rocm", "cuda"]
            },
            "uniqueItems": true
          }
        }
      }
    }
  },
  "additionalProperties": false
}
